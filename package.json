{
  "name": "@koushikmondal06/comet",
  "version": "1.2.8",
  "description": "AI-powered commit message generator CLI",
  "main": "dist/index.js",
  "bin": {
    "comet": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Koushikmondal06/Comet.git"
  },
  "homepage": "https://github.com/Koushikmondal06/Comet#readme",
  "bugs": {
    "url": "https://github.com/Koushikmondal06/Comet/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "cli",
    "gemini",
    "openai",
    "commit-message"
  ],
  "author": "Koushik Mondal",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^5.5.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
